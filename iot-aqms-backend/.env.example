# Server
PORT=3000

# MongoDB
MONGODB_URI=mongodb://localhost:27017/aqms

# JWT
JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRES_IN=8h

# CORS (set to frontend URL in production)
CORS_ORIGIN=http://localhost:5173

# IoT Device authentication key
# ESP8266 must send this in the X-Device-Key header
# Leave empty to disable device auth (development only)
DEVICE_API_KEY=change_this_to_a_secret_device_key
